NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# AI rate limit per user per day. Default: 10
# Set to 'unlimited' to disable rate limiting entirely (testing/dev only — NEVER in production).
# Example values: 10 (default), 100 (loose testing), unlimited (disabled).
AI_DAILY_LIMIT=10

# Stage 2 (theme generation) model. Defaults to claude-haiku-4-5.
# Set to claude-sonnet-4-6 for better creative output (3x cost).
# Set on Vercel for production toggle without code changes.
THEME_GENERATION_MODEL=claude-haiku-4-5

# Tone-conditional override: when the wizard's tone === 'casual' (Bisedor),
# generate-variants uses this model instead of THEME_GENERATION_MODEL.
# Justification: A/B testing showed Sonnet produces authentic road-Gheg
# apostrophe forms (n'Tavnik, me u shqetësu) where Haiku stays in standard
# register. For other tones the difference is marginal so Haiku is fine.
# Defaults to claude-sonnet-4-6 if unset.
CASUAL_THEME_MODEL=claude-sonnet-4-6